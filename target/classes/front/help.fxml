<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            style="-fx-background: transparent;">

    <content>
        <VBox spacing="16" style="-fx-background-color: #f3f4f6;">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <Label text="Help and Commands"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

            <Label text="Here you can find examples of voice commands and how to use the application."
                   style="-fx-text-fill: #374151;"/>

            <!-- Card: Voice Commands -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>

                <Label text="Voice commands examples"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <Label text="• 'Open files'  → opens the files page"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• 'Create file' → opens create file form"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• 'Delete file' → opens delete file page"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• 'Read file'   → opens read file page"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• 'Update file' → opens update file page"
                       style="-fx-text-fill: #4b5563;"/>
            </VBox>

            <!-- Card: File Operations -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>

                <Label text="File operations"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <Label text="• Create: enter name + content, then click Save"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• Read: select a file then click Open"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• Update: choose file, edit content, then click Update"
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• Delete: select file, confirm deletion"
                       style="-fx-text-fill: #4b5563;"/>
            </VBox>

            <!-- Card: Tips -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>

                <Label text="Tips"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                <Label text="• If a page doesn't open, check the FXML path in the controller."
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• If login fails, verify your database credentials and user role."
                       style="-fx-text-fill: #4b5563;"/>
                <Label text="• Keep one ADMIN account always enabled for management."
                       style="-fx-text-fill: #4b5563;"/>
            </VBox>

            <HBox spacing="10">
                <Button text="Back"
                        onAction="#onBack"
                        style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827; -fx-background-radius: 10; -fx-padding: 10 16;"/>
            </HBox>

        </VBox>
    </content>
</ScrollPane>