<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@/styles/app.css"
      spacing="16">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Home" styleClass="title"/>
    <Label text="Welcome. Use the menu to access voice commands and file operations."
           styleClass="subtitle"/>

    <HBox styleClass="card">
        <VBox spacing="8">
            <Label text="Quick Start" styleClass="title"/>
            <Label text="1) Open Voice Commands"/>
            <Label text="2) Speak a command"/>
            <Label text="3) Confirm the action"/>
        </VBox>
    </HBox>

</VBox>