<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.front.LoginController"
            stylesheets="@/styles/app.css">

    <center>
        <VBox spacing="14" styleClass="page" maxWidth="420">
            <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

            <Label text="Sign in" styleClass="title"/>
            <Label text="Use your email and password to continue." styleClass="subtitle"/>

            <Label text="Email"/>
            <TextField fx:id="emailField" promptText="name@email.com"/>

            <Label text="Password"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"/>

            <Label fx:id="messageLabel" visible="false" wrapText="true"/>

            <Button text="Login" onAction="#onLogin" styleClass="primary-btn" maxWidth="Infinity"/>
            <Button text="Create an account" onAction="#goRegister" styleClass="link-btn" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>