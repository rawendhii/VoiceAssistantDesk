<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.back.RolesListController"
            style="-fx-background-color: #f3f4f6;">

    <top>
        <VBox spacing="10">
            <padding><Insets top="18" right="18" bottom="12" left="18"/></padding>
            <Label text="Gestion des rôles" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Rechercher un rôle..." prefWidth="320"/>
                <Button text="Rechercher" onAction="#onSearch"/>
                <Button text="Actualiser" onAction="#onRefresh"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="messageLabel" visible="false"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="14">
            <padding><Insets top="0" right="18" bottom="18" left="18"/></padding>

            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="Liste" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TableView fx:id="rolesTable" prefHeight="420">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colName" text="Nom" prefWidth="260"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="Charger sélection" onAction="#onLoadSelected"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Supprimer" onAction="#onDelete"/>
                </HBox>
            </VBox>

            <VBox spacing="12" prefWidth="320"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e5e7eb;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Formulaire" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="80" prefWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="ID"/>
                    <TextField fx:id="idField" editable="false" promptText="Auto" GridPane.columnIndex="1"/>

                    <Label text="Nom" GridPane.rowIndex="1"/>
                    <TextField fx:id="nameField" promptText="ADMIN / USER ..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator/>

                <HBox spacing="10">
                    <Button text="Ajouter" onAction="#onAdd" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                    <Button text="Modifier" onAction="#onUpdate" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button text="Vider" onAction="#onClear" maxWidth="1.7976931348623157E308"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>