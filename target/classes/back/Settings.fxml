<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      spacing="14" style="-fx-background-color: #f3f4f6;">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <Label text="Settings" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
    <Label text="Configuration placeholders (API, speech engine, security)."
           style="-fx-text-fill: #374151;"/>

    <HBox style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <VBox spacing="6">
            <Label text="Database: MySQL (configured)" style="-fx-text-fill: #111827;"/>
            <Label text="Speech-to-Text: planned" style="-fx-text-fill: #111827;"/>
            <Label text="Text-to-Speech: planned" style="-fx-text-fill: #111827;"/>
            <Label text="Security rules: allowed commands list" style="-fx-text-fill: #111827;"/>
        </VBox>
    </HBox>
</VBox>