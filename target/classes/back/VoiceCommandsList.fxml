<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.back.VoiceCommandsListController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #f8fafc;">

    <top>
        <VBox spacing="12.0" style="-fx-padding: 20;">
            <Label text="Voice Commands Management"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

            <HBox spacing="10.0">
                <TextField fx:id="searchField"
                           promptText="Search by label, keyword, or description..."
                           prefWidth="320.0" />

                <Button text="Search" onAction="#onSearch" />
                <Button text="Refresh" onAction="#onRefresh" />
                <Button text="Load Selected" onAction="#onLoadSelected" />
                <Button text="Clear" onAction="#onClear" />
            </HBox>

            <Label fx:id="messageLabel"
                   text=""
                   visible="false"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;" />
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.62">
            <items>

                <VBox spacing="10.0" style="-fx-padding: 20;">
                    <Label text="Voice Commands List"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                    <TableView fx:id="commandsTable" prefHeight="500.0">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="70.0" />
                            <TableColumn fx:id="colLabel" text="Label" prefWidth="170.0" />
                            <TableColumn fx:id="colKeyword" text="Keyword" prefWidth="170.0" />
                            <TableColumn fx:id="colDescription" text="Description" prefWidth="280.0" />
                            <TableColumn fx:id="colActive" text="Active" prefWidth="90.0" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="14.0" style="-fx-padding: 20;">
                    <Label text="Voice Command Form"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                    <GridPane hgap="10.0" vgap="12.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="110.0" prefWidth="110.0" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="idField" editable="false"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Label:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="labelField" promptText="e.g. Create File"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Label text="Keyword:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="keywordField" promptText="e.g. create file"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1" />

                        <Label text="Description:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextArea fx:id="descriptionArea"
                                  promptText="Describe what this command does..."
                                  prefRowCount="5"
                                  wrapText="true"
                                  GridPane.rowIndex="3" GridPane.columnIndex="1" />

                        <Label text="Active:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <CheckBox fx:id="activeCheckBox"
                                  text="Enabled"
                                  GridPane.rowIndex="4" GridPane.columnIndex="1" />
                    </GridPane>

                    <HBox spacing="10.0">
                        <Button text="Add" onAction="#onAdd" prefWidth="90.0" />
                        <Button text="Update" onAction="#onUpdate" prefWidth="90.0" />
                        <Button text="Delete" onAction="#onDelete" prefWidth="90.0" />
                    </HBox>
                </VBox>

            </items>
        </SplitPane>
    </center>

    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
    </padding>
</BorderPane>