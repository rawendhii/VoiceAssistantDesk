<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.back.CommandsHistoryController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #f8fafc;">

    <top>
        <VBox spacing="12.0" style="-fx-padding: 20;">
            <Label text="Command History"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

            <HBox spacing="10.0">
                <TextField fx:id="searchField"
                           promptText="Search by user, command, or executed text..."
                           prefWidth="320.0" />

                <ComboBox fx:id="statusFilterCombo" prefWidth="140.0" />

                <Button text="Search" onAction="#onSearch" />
                <Button text="Refresh" onAction="#onRefresh" />
                <Button text="Delete Selected" onAction="#onDelete" />
            </HBox>

            <Label fx:id="messageLabel"
                   text=""
                   visible="false"
                   style="-fx-font-size: 13px; -fx-font-weight: bold;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0" style="-fx-padding: 20;">
            <Label text="Executed Commands History"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

            <TableView fx:id="historyTable" prefHeight="560.0">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="70.0" />
                    <TableColumn fx:id="colUser" text="User" prefWidth="160.0" />
                    <TableColumn fx:id="colCommand" text="Command" prefWidth="170.0" />
                    <TableColumn fx:id="colExecutedText" text="Executed Text" prefWidth="300.0" />
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="110.0" />
                    <TableColumn fx:id="colExecutedAt" text="Executed At" prefWidth="220.0" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
    </padding>
</BorderPane>