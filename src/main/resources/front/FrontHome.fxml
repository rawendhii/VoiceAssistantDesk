<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@/styles/app.css"
      spacing="20"
      alignment="TOP_CENTER"
      prefHeight="400"
      prefWidth="600">

    <padding>
        <Insets top="40" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Bienvenue sur l'Assistant Vocal" styleClass="title">
        <font><Font size="28"/></font>
    </Label>

    <Label text="Utilisez votre voix pour interagir avec l'application"
           style="-fx-font-size: 16px; -fx-text-fill: #4b5563;"/>

    <HBox styleClass="card">
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <Label text="Commandes vocales disponibles :" 
                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1f2937;"/>
            <Label text="• 'créer fichier' - Créer un nouveau fichier" 
                   style="-fx-text-fill: #4b5563;"/>
            <Label text="• 'lire fichier' - Lire le contenu d'un fichier" 
                   style="-fx-text-fill: #4b5563;"/>
            <Label text="• 'modifier fichier' - Modifier un fichier" 
                   style="-fx-text-fill: #4b5563;"/>
            <Label text="• 'supprimer fichier' - Supprimer un fichier" 
                   style="-fx-text-fill: #4b5563;"/>
            <Label text="• 'liste fichiers' - Afficher la liste des fichiers" 
                   style="-fx-text-fill: #4b5563;"/>
            <Label text="• 'aide' - Afficher l'aide" 
                   style="-fx-text-fill: #4b5563;"/>
        </VBox>
    </HBox>

</VBox>