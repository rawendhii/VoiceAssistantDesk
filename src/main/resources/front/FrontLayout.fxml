<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.front.FrontLayoutController"
            stylesheets="@/styles/app.css">

    <top>
        <HBox spacing="12" style="-fx-background-color: #0f172a;" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>

            <Label text="Assistant Vocal" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Front Office" style="-fx-text-fill: white; -fx-opacity: 0.85;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="240" style="-fx-background-color: #111827;" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="14" right="12" bottom="14" left="12"/>
            </padding>

            <Button text="Home" maxWidth="1.7976931348623157E308" onAction="#goHome"/>
            <Button text="Voice Commands" maxWidth="1.7976931348623157E308" onAction="#goVoice"/>
            <Button text="Files" maxWidth="1.7976931348623157E308" onAction="#goFiles"/>
            <Button text="Profile" maxWidth="1.7976931348623157E308" onAction="#goProfile"/>

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>