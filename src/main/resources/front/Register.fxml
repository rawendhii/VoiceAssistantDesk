<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.front.RegisterController"
            stylesheets="@/styles/app.css">

    <center>
        <VBox spacing="14" styleClass="page" maxWidth="420">
            <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

            <Label text="Create account" styleClass="title"/>
            <Label text="Fill your details to register." styleClass="subtitle"/>

            <Label text="Full name"/>
            <TextField fx:id="fullNameField" promptText="Your name"/>

            <Label text="Email"/>
            <TextField fx:id="emailField" promptText="name@email.com"/>

            <Label text="Password"/>
            <PasswordField fx:id="passwordField" promptText="Min 6 characters"/>

            <Label fx:id="messageLabel" visible="false" wrapText="true"/>

            <Button text="Register" onAction="#onRegister" styleClass="primary-btn" maxWidth="Infinity"/>
            <Button text="Back to login" onAction="#goLogin" styleClass="link-btn" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>