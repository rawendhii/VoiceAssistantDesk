<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1"
      spacing="14" style="-fx-background-color: #f3f4f6;">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <Label text="Files" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
    <Label text="Browse and manage files. Advanced file actions will be connected later."
           style="-fx-text-fill: #374151;"/>

    <HBox spacing="10">
        <TextField promptText="Search file..." prefWidth="260"/>
        <Button text="Search"/>
        <Button text="Refresh"/>
    </HBox>

    <VBox style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 10; -fx-background-radius: 10;">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        <TableView prefHeight="320">
            <columns>
                <TableColumn text="Name" prefWidth="280"/>
                <TableColumn text="Type" prefWidth="120"/>
                <TableColumn text="Size" prefWidth="120"/>
                <TableColumn text="Modified" prefWidth="180"/>
            </columns>
        </TableView>
    </VBox>
</VBox>